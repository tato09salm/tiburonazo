generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CLIENTE)
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  sales     Sale[]   @relation("VendedorSales")

  @@map("users")
}

model Section {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[] @relation("ProductSections")

  @@map("sections")
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]

  @@map("categories")
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  logoUrl  String?
  products Product[]

  @@map("brands")
}

model Product {
  id          String           @id @default(cuid())
  code        String           @unique
  title       String
  slug        String           @unique
  description String?
  material    String?
  gender      Gender           @default(UNISEX)
  weight      Float?
  isActive    Boolean          @default(true)
  isFeatured  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  categoryId  String
  brandId     String?
  linea       String?
  images      ProductImage[]
  variants    ProductVariant[]
  brand       Brand?           @relation(fields: [brandId], references: [id])
  category    Category         @relation(fields: [categoryId], references: [id])
  sections    Section[]        @relation("ProductSections")

  @@map("products")
}

model ProductVariant {
  id             String          @id @default(cuid())
  sku            String          @unique
  model          String?
  price          Float
  oldPrice       Float?
  stock          Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  productId      String
  colorId        String?
  sizeId         String?
  inventoryMoves InventoryMove[]
  orderItems     OrderItem[]
  color          Color?          @relation(fields: [colorId], references: [id])
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  size           Size?           @relation(fields: [sizeId], references: [id])
  saleItems      SaleItem[]

  @@map("product_variants")
}

model Color {
  id       String           @id @default(cuid())
  name     String           @unique
  hex      String?
  images   ProductImage[]
  variants ProductVariant[]

  @@map("colors")
}

model Size {
  id        String           @id @default(cuid())
  label     String           @unique
  category  String?
  sortOrder Int              @default(0)
  variants  ProductVariant[]

  @@map("sizes")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  order     Int     @default(0)
  productId String
  colorId   String?
  color     Color?  @relation(fields: [colorId], references: [id])
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Store {
  id             String          @id @default(cuid())
  name           String          @unique
  address        String?
  inventoryMoves InventoryMove[]
  sales          Sale[]

  @@map("stores")
}

model InventoryMove {
  id        String         @id @default(cuid())
  code      String         @unique
  date      DateTime       @default(now())
  type      MoveType
  quantity  Int
  reason    String?
  note      String?
  createdAt DateTime       @default(now())
  variantId String
  storeId   String
  store     Store          @relation(fields: [storeId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("inventory_moves")
}

model Order {
  id            String         @id @default(cuid())
  code          String         @unique
  status        OrderStatus    @default(PENDIENTE)
  paymentMethod PaymentMethod?
  total         Float
  shippingCost  Float          @default(0)
  address       String?
  notes         String?
  culqiChargeId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  items         OrderItem[]
  user          User           @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id        String         @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  variantId String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Sale {
  id            String        @id @default(cuid())
  code          String        @unique
  date          DateTime      @default(now())
  paymentMethod PaymentMethod
  total         Float
  destination   String?
  notes         String?
  createdAt     DateTime      @default(now())
  storeId       String
  vendedorId    String?
  items         SaleItem[]
  store         Store         @relation(fields: [storeId], references: [id])
  vendedor      User?         @relation("VendedorSales", fields: [vendedorId], references: [id])

  @@map("sales")
}

model SaleItem {
  id        String         @id @default(cuid())
  quantity  Int
  price     Float
  saleId    String
  variantId String
  sale      Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("sale_items")
}

enum Role {
  ADMIN
  VENDEDOR
  CLIENTE
}

enum Gender {
  ADULTO
  NINO
  BEBE
  UNISEX
}

enum MoveType {
  ENTRADA
  SALIDA
  AJUSTE
  TRASLADO
}

enum OrderStatus {
  PENDIENTE
  PAGADO
  ENVIADO
  ENTREGADO
  CANCELADO
}

enum PaymentMethod {
  CULQI
  YAPE
  PLIN
  EFECTIVO
  TRANSFERENCIA
}
