generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  VENDEDOR
  CLIENTE
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CLIENTE)
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  sales     Sale[]   @relation("VendedorSales")

  @@map("users")
}

// ─── CATALOG ─────────────────────────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  logoUrl  String?
  products Product[]

  @@map("brands")
}

enum Gender {
  ADULTO
  NINO
  BEBE
  UNISEX
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  slug        String   @unique
  description String?
  material    String?
  linea       String?
  gender      Gender   @default(UNISEX)
  weight      Float?
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  variants   ProductVariant[]
  images     ProductImage[]

  @@map("products")
}

model ProductVariant {
  id         String   @id @default(cuid())
  sku        String   @unique
  model      String?   // modelo (para accesorios)
  price      Float
  oldPrice   Float?    // precio anterior tachado
  stock      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  colorId String?
  color   Color?  @relation(fields: [colorId], references: [id])

  sizeId String?
  size   Size?   @relation(fields: [sizeId], references: [id])

  orderItems     OrderItem[]
  inventoryMoves InventoryMove[]
  saleItems      SaleItem[]

  @@map("product_variants")
}

model Color {
  id       String           @id @default(cuid())
  name     String           @unique  // "Rojo", "Azul marino"
  hex      String?                   // "#FF0000" (opcional, para UI)
  variants ProductVariant[]
  images   ProductImage[]

  @@map("colors")
}

model Size {
  id        String           @id @default(cuid())
  label     String           @unique  // "XS", "S", "M", "L", "XL", "4", "6"...
  category  String?                   // "ropa", "aletas", "único" — para agrupar
  sortOrder Int              @default(0) // para ordenar correctamente en el frontend
  variants  ProductVariant[]

  @@map("sizes")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  order     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  colorId String?
  color   Color?  @relation(fields: [colorId], references: [id])

  @@map("product_images")
}

// ─── STORES ──────────────────────────────────────────────────────────────────

model Store {
  id             String          @id @default(cuid())
  name           String          @unique
  address        String?
  inventoryMoves InventoryMove[]
  sales          Sale[]

  @@map("stores")
}

// ─── INVENTORY ───────────────────────────────────────────────────────────────

enum MoveType {
  ENTRADA
  SALIDA
  AJUSTE
  TRASLADO
}

model InventoryMove {
  id          String    @id @default(cuid())
  code        String    @unique
  date        DateTime  @default(now())
  type        MoveType
  quantity    Int
  reason      String?
  note        String?
  createdAt   DateTime  @default(now())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  storeId String
  store   Store @relation(fields: [storeId], references: [id])

  @@map("inventory_moves")
}

// ─── ORDERS (E-commerce) ─────────────────────────────────────────────────────

enum OrderStatus {
  PENDIENTE
  PAGADO
  ENVIADO
  ENTREGADO
  CANCELADO
}

enum PaymentMethod {
  CULQI
  YAPE
  PLIN
  EFECTIVO
  TRANSFERENCIA
}

model Order {
  id            String        @id @default(cuid())
  code          String        @unique
  status        OrderStatus   @default(PENDIENTE)
  paymentMethod PaymentMethod?
  total         Float
  shippingCost  Float         @default(0)
  address       String?
  notes         String?
  culqiChargeId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id       String @id @default(cuid())
  quantity Int
  price    Float

  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ─── SALES (POS físico) ──────────────────────────────────────────────────────

model Sale {
  id            String        @id @default(cuid())
  code          String        @unique
  date          DateTime      @default(now())
  paymentMethod PaymentMethod
  total         Float
  destination   String?
  notes         String?
  createdAt     DateTime      @default(now())

  storeId String
  store   Store @relation(fields: [storeId], references: [id])

  vendedorId String?
  vendedor   User?   @relation("VendedorSales", fields: [vendedorId], references: [id])

  items SaleItem[]

  @@map("sales")
}

model SaleItem {
  id       String @id @default(cuid())
  quantity Int
  price    Float

  saleId    String
  sale      Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("sale_items")
}
